# LETHE — SELinux file context labels (v1.1 — Tor + userspace scripts)
#
# Tor entries shipped in v1.0 (sepolicy/tor.te); script entries added in
# v1.1 (sepolicy/lethe.te). Each .sh script gets lethe_exec so init can
# either execute_no_trans (privileged scripts staying in init: via init.rc
# seclabel) or type_transition to the lethe: domain (network/IPC scripts
# without seclabel). See sepolicy/lethe.te for the two-domain split.

# ── Tor daemon (v1.0) ──
/system/bin/tor                         u:object_r:tor_exec:s0
/data/lethe/tor(/.*)?                   u:object_r:tor_data_file:s0

# ── LETHE userspace scripts (v1.1) ──
/system/bin/lethe-burner-wipe\.sh       u:object_r:lethe_exec:s0
/system/bin/lethe-mac-rotate\.sh        u:object_r:lethe_exec:s0
/system/bin/lethe-tor-rules\.sh         u:object_r:lethe_exec:s0
/system/bin/lethe-tor-pt-select\.sh     u:object_r:lethe_exec:s0
/system/bin/lethe-apply-settings\.sh    u:object_r:lethe_exec:s0

# ── Device Owner setup (v1.2) ──
# One-shot at first boot; binders into DevicePolicyManagerService to promote
# LetheDeviceAdmin. Runs in the lethe domain — already has system_server:binder.
/system/bin/lethe-set-device-owner\.sh  u:object_r:lethe_exec:s0

# ── Agent launcher (v1.2) ──
# Wraps the Rust backend; idles when bender/ isn't packaged. Without this
# lethe_exec label the init service fail-loops on { entrypoint } AVC denials
# because init.lethe-agent.rc puts the service in the lethe domain.
/system/bin/lethe-agent-start\.sh       u:object_r:lethe_exec:s0
