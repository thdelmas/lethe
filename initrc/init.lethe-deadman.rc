# Lethe dead man's switch — boot enforcement + runtime monitor.
# Uses standalone scripts (inline shell breaks on Android 7.1 init).

service lethe-deadman-boot /system/bin/lethe-deadman-boot.sh
    class main
    user root
    group root
    oneshot
    seclabel u:r:init:s0

service lethe-deadman-monitor /system/bin/lethe-deadman-monitor.sh
    class late_start
    user root
    group root
    disabled
    seclabel u:r:init:s0

service lethe-deadman-duress /system/bin/lethe-deadman-duress.sh
    class main
    user root
    group root
    oneshot
    disabled
    seclabel u:r:init:s0

on post-fs-data
    mkdir /data/lethe/deadman 0700 root root
    start lethe-deadman-boot

on property:sys.boot_completed=1
    start lethe-deadman-monitor

on property:persist.lethe.deadman.duress_triggered=true
    start lethe-deadman-duress
