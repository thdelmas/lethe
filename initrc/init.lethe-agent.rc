# LETHE — native AI agent layer
# Starts the Rust backend on localhost:8080 and registers as default assist app.

service lethe-agent /system/bin/lethe-agent-start.sh
    class late_start
    user root
    group root inet
    disabled
    seclabel u:r:lethe:s0

# Device Owner promotion is no longer an init service. The shell-out path
# required granting the `lethe` SELinux domain zygote_exec perms to invoke
# pm/dpm (#145); we now do it from BootReceiver.onReceive, which runs in
# the platform_app domain and can talk to DPMS directly. Same trigger
# window — BOOT_COMPLETED fires before setup wizard sets DEVICE_PROVISIONED.

on property:sys.boot_completed=1
    start lethe-agent
