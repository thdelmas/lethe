# LETHE — native AI agent layer
# Starts the Rust backend on localhost:8080 and registers as default assist app.

service lethe-agent /system/bin/lethe-agent-start.sh
    class late_start
    user root
    group root inet
    disabled
    seclabel u:r:lethe:s0

# One-shot Device Owner promotion (see scripts/runtime/lethe-set-device-owner.sh).
# Idempotent: bails if persist.lethe.device_owner_set=true. Must run after
# sys.boot_completed=1 so PackageManager + the `dpm` shell tool are up.
# cm-14.1 caps service names at 16 chars — lethe_set_owner is 15, safe.
service lethe_set_owner /system/bin/lethe-set-device-owner.sh
    class late_start
    user root
    group root
    oneshot
    disabled

on property:sys.boot_completed=1
    start lethe-agent
    start lethe_set_owner
