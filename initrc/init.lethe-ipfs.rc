# Lethe — IPFS OTA update client
# Runs a lightweight IPFS node in client-only mode (no DHT serving).
# All swarm traffic routed through Tor SOCKS proxy.
# Periodically runs lethe-ota-update.sh to check for signed updates.

service lethe-ipfs /system/bin/sh -c "\
    export IPFS_PATH=/data/lethe/ipfs; \
    if [ ! -d \$IPFS_PATH ]; then \
        ipfs init --profile=lowpower 2>/dev/null; \
        ipfs config Routing.Type dhtclient; \
        ipfs config --json Swarm.DisableNatPortMap true; \
        ipfs config --json Gateway.NoFetch true; \
        ipfs config Addresses.Gateway ''; \
        ipfs config Addresses.API /ip4/127.0.0.1/tcp/5001; \
        ipfs config --json Swarm.ProxyCommand '[\"connect-proxy\", \"-S\", \"127.0.0.1:9050\"]'; \
    fi; \
    ipfs daemon --routing=dhtclient 2>&1 | log -t lethe-ipfs"
    class late_start
    user 9051
    group 9051 inet
    disabled
    seclabel u:r:lethe:s0

service lethe-ota-check /system/bin/sh -c "\
    while true; do \
        sleep 21600; \
        ENABLED=\$(getprop persist.lethe.ipfs.enabled); \
        if [ \"\$ENABLED\" != \"true\" ]; then continue; fi; \
        \
        /system/bin/lethe-ota-update.sh 2>&1 | log -t lethe-ota; \
        /system/bin/lethe-channel-sync.sh 2>&1 | log -t lethe-channels; \
    done"
    class late_start
    oneshot
    disabled
    seclabel u:r:lethe:s0

# One-shot check shortly after boot (5 min delay for connectivity).
service lethe-ota-boot /system/bin/sh -c "\
    sleep 300; \
    ENABLED=\$(getprop persist.lethe.ipfs.enabled); \
    if [ \"\$ENABLED\" = \"true\" ]; then \
        /system/bin/lethe-ota-update.sh 2>&1 | log -t lethe-ota; \
    fi"
    class late_start
    oneshot
    disabled
    seclabel u:r:lethe:s0

service lethe-channels-init /system/bin/lethe-channels-init.sh
    class late_start
    user 9051
    group 9051
    oneshot
    disabled
    seclabel u:r:lethe:s0

on property:sys.boot_completed=1
    mkdir /data/lethe/ipfs 0700 9051 9051
    mkdir /data/lethe/ota 0700 9051 9051
    mkdir /data/lethe/channels 0700 9051 9051
    mkdir /data/lethe/advisories 0700 9051 9051
    mkdir /persist/lethe/channels 0700 9051 9051
    start lethe-channels-init
    start lethe-ipfs
    start lethe-ota-check
    start lethe-ota-boot
