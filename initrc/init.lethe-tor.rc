# Lethe — Tor transparent proxy
# Starts Tor daemon and applies iptables rules via standalone script.
# cm-14.1 init parser rejects hyphens in service names — using underscores.
# `capabilities` keyword is Android 8+ only; on cm-14.1 (Android 7.1) we
# inherit init's capabilities by running with seclabel u:r:init:s0.
#
# lethe_tor (the daemon) intentionally has NO seclabel — type_transition in
# sepolicy/tor.te puts it in the `tor` domain via the tor_exec label on
# /system/bin/tor. Adding seclabel here would override that transition and
# put the daemon back in init: domain, where it cannot execute_no_trans
# (the original v1.0.x boot regression). lethe_tor_rules and lethe_tor_pt
# keep seclabel u:r:init:s0 because their sepolicy fix is deferred to v1.1.

service lethe_tor /system/bin/tor -f /system/etc/tor/torrc
    class main
    user root
    group root inet net_admin
    disabled

service lethe_tor_rules /system/bin/lethe-tor-rules.sh
    class main
    user root
    group root inet net_admin
    oneshot
    disabled

# Pluggable-transport selector (lethe#108). Reads
# persist.lethe.tor.bridge_pt and writes /data/lethe/tor/torrc.bridges
# before tor starts, so changing the PT is one setprop + reboot.
service lethe_tor_pt /system/bin/lethe-tor-pt-select.sh
    class main
    user root
    group root
    oneshot

# Remote-DMS hidden service selector (lethe#103). Reads
# persist.lethe.remote_dms.enabled and writes
# /data/lethe/tor/torrc.remote_dms before tor starts.
service lethe_tor_rdms /system/bin/lethe-tor-remote-dms.sh
    class main
    user root
    group root
    oneshot

on post-fs-data
    mkdir /data/lethe 0700 root root
    mkdir /data/lethe/tor 0700 root root
    # Re-assert root ownership of DataDirectory each boot. mkdir above is
    # a no-op if the dir already exists, so a prior boot that chowned it
    # to a different uid (e.g. an earlier pt-select version) would leave
    # it misaligned with Tor's expected ownership. Tor runs as root in
    # v1.0/v1.1; ownership mismatch makes it exit at startup.
    chown root root /data/lethe/tor
    chmod 0700 /data/lethe/tor
    # Pre-create empty torrc.bridges so torrc's %include succeeds even when
    # lethe_tor_pt is skipped or fails. Without this, Tor exits 1 on
    # missing-include.
    write /data/lethe/tor/torrc.bridges ""
    chown root root /data/lethe/tor/torrc.bridges
    chmod 0600 /data/lethe/tor/torrc.bridges
    # Same shape for the remote-DMS hidden-service fragment (lethe#103).
    write /data/lethe/tor/torrc.remote_dms ""
    chown root root /data/lethe/tor/torrc.remote_dms
    chmod 0600 /data/lethe/tor/torrc.remote_dms
    # State file: delete on every boot. Tor refuses to bootstrap if the
    # state file's timestamp is in the future relative to the current
    # clock (CLOCK_SKEW check). On a device with no RTC battery and no
    # NTP sync at boot, this fires every time. Burner mode is supposed
    # to handle this via /data wipe but the wipe is restricted under
    # enforcing SELinux (system_data_file neverallow). Bandaid:
    # delete /data/lethe/tor/state here so Tor always starts fresh.
    rm /data/lethe/tor/state
    rm /data/lethe/tor/lock
    start lethe_tor_pt
    start lethe_tor_rdms

on property:sys.boot_completed=1
    start lethe_tor
    start lethe_tor_rules
