# Lethe burner mode — wipe + identity rotation
# Uses standalone scripts (inline shell breaks on Android 7.1 init).

service lethe-burner-wipe /system/bin/lethe-burner-wipe.sh
    class main
    user root
    group root
    oneshot
    seclabel u:r:init:s0

service lethe-mac-rotate /system/bin/lethe-mac-rotate.sh
    class core
    user root
    group root inet net_admin
    oneshot
    disabled
    seclabel u:r:init:s0

on post-fs-data
    start lethe-burner-wipe
    start lethe-mac-rotate
